{
  "name": "@turbowasm/gpu-kernel-parser",
  "version": "0.2.0",
  "description": "Parser and formatter for the TurboWasm @compute kernel DSL used by `.scgpu` files.",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./comment-parser": {
      "types": "./dist/comment-parser.d.ts",
      "import": "./dist/comment-parser.js",
      "require": "./dist/comment-parser.cjs"
    },
    "./document-parser": {
      "types": "./dist/document-parser.d.ts",
      "import": "./dist/document-parser.js",
      "require": "./dist/document-parser.cjs"
    },
    "./formatters": {
      "types": "./dist/formatters.d.ts",
      "import": "./dist/formatters.js",
      "require": "./dist/formatters.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./directives": {
      "types": "./dist/directives.d.ts",
      "import": "./dist/directives.js",
      "require": "./dist/directives.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test --max-warnings 0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "8.15.0",
    "@typescript-eslint/parser": "8.15.0",
    "esbuild": "^0.25.0",
    "eslint": "8.57.1",
    "typescript": "5.6.3",
    "vitest": "^4.1.9"
  }
}
