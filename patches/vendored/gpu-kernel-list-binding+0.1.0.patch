+    /**
+     * Look up a list by name (case-insensitive, lower-cased to match
+     * scratch-vm's storage convention) and return a typed-array-backed
+     * view of its current contents in the requested dtype.
+     * @param {string} name list name.
+     * @param {'f32'|'i32'|'byte'} [dtype='f32'] ABI dtype.
+     * @return {{data: Float32Array|Int32Array|Uint8Array, length: number, dtype: string} | null}
+     */
+    __getListBuffer (name, dtype) {
+        const lowerName = typeof name === 'string' ? name.toLowerCase() : '';
+        const wantDtype = dtype || 'f32';
+        for (const target of this.targets) {
+            if (!target || !target.variables) continue;
+            for (const varId of Object.keys(target.variables)) {
+                const v = target.variables[varId];
+                if (v && v.type === 'list' && v.name && v.name.toLowerCase() === lowerName) {
+                    return this.__getListBufferById(varId, wantDtype);
+                }
+            }
+        }
+        return null;
+    }
+
