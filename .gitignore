node_modules
dist
dist-ssr
*.local
.env.local
.env.*.local

# Generated test fixtures — never tracked, regenerated by
# `scripts/ensure-test-fixtures.mjs` on demand and by `npm run fixtures:setup`.
# The `.gitkeep` exception keeps the directory itself present on fresh clones
# so scripts can rely on the path existing.
.test-fixtures/*
!.test-fixtures/.gitkeep

# Legacy fixture directory from before the `.test-fixtures/` migration.
# Kept ignored so a leftover `test-fixtures/*.sb3` is not accidentally
# committed back into the repo. All generators now write to
# `.test-fixtures/` exclusively.
test-fixtures/

# Local vendored forks (scratch-vm, scaffolding) for VM perf work
/vendored/

# Rust/WASM toolchain outputs (TurboWasm collision crate)
wasm-collision/target/
wasm-collision/pkg/
wasm-collision/Cargo.lock

# Editors
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
AGENTS.md

# Logs
logs/

# Build
*.tsbuildinfo
.tsbuildinfo-node/

# Test coverage
coverage/
*.lcov

# Env (only .env.example is meant to be tracked)
.env
.env.*.bak
