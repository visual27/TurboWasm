{
  "name": "turbowasm-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A minimal, statically-deployed SB3 viewer built on TurboWarp Scaffolding.",
  "scripts": {
    "setup": "node scripts/setup-vendored.mjs",
    "setup:vendored": "node scripts/setup-vendored.mjs",
    "dev": "npm run wasm:build && vite",
    "build": "npm run setup:vendored && npm run wasm:build && tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "wasm:build": "node scripts/build-wasm.mjs",
    "wasm:dev": "node scripts/build-wasm.mjs --dev",
    "wasm:check": "cd wasm-collision && cargo check --target wasm32-unknown-unknown",
    "postinstall": "node scripts/apply-vendored-patches.mjs",
    "apply:scratch-render-patch": "node scripts/apply-vendored-patches.mjs",
    "fixtures:setup": "node scripts/ensure-test-fixtures.mjs",
    "pretest": "node scripts/ensure-test-fixtures.mjs",
    "make:svg-sprite-fixture": "node scripts/make-svg-sprite-fixture.mjs",
    "verify:turbowarp-equivalent": "node scripts/verify-turbowarp-equivalent.mjs",
    "verify:stage2-metrics": "node scripts/verify-stage2-metrics.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-scroll-area": "1.2.1",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-slider": "1.2.1",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-switch": "1.1.1",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.4",
    "@turbowarp/scaffolding": "0.4.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "jszip": "3.10.1",
    "lucide-react": "0.460.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.4",
    "tailwindcss-animate": "1.0.7",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.12.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.15.0",
    "@typescript-eslint/parser": "8.15.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-refresh": "0.4.14",
    "jsdom": "^26.1.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
